{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& (Join-Path $PWD '.command-gate\\hooks\\gate_check.ps1')",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& (Join-Path $PWD '.command-gate\\hooks\\evidence_capture.ps1')",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& (Join-Path $PWD '.command-gate\\hooks\\evidence_capture.ps1')",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
